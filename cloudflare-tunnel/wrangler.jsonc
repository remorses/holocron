// wrangler.jsonc
{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ws-tunnel",
  "main": "src/tunnel.ts",
  "compatibility_date": "2025-06-27",
  "account_id": "103e73569e2f6d4aea0fb679ceb8709b",

  "workers_dev": false,

  // ↓ narrower pattern
  "routes": [
    {
      "pattern": "holocron.so/_tunnel/*",
      "zone_name": "holocron.so",
    },
    {
      "pattern": "fumabase.com/_tunnel/*",
      "zone_name": "fumabase.com",
    },
    // unframer.co/_tunnel/* and mcp.unframer.co/_tunnel/* moved to the MCP worker (plugin-mcp)
    // Command: cd /Users/morse/Documents/GitHub/fumabase/cloudflare-tunnel && pnpm deployment:prod
    {
      "pattern": "opentui.net/_tunnel/*",
      "zone_name": "opentui.net",
    },
  ],

  "durable_objects": {
    "bindings": [{ "name": "TUNNEL_DO", "class_name": "Tunnel" }],
  },

  "migrations": [{ "tag": "v1", "new_classes": ["Tunnel"] }],

  "env": {
    "preview": {
      "routes": [
        {
          "pattern": "preview.fumabase.com/_tunnel/*",
          "zone_name": "fumabase.com",
        },
        {
          "pattern": "preview.holocron.so/_tunnel/*",
          "zone_name": "holocron.so",
        },
        // mcp.preview.unframer.co/_tunnel/* and preview.unframer.co/_tunnel/*
        // moved to the MCP worker (plugin-mcp)
        {
          "pattern": "preview.opentui.net/_tunnel/*",
          "zone_name": "opentui.net",
        },
      ],
      "durable_objects": {
        "bindings": [{ "name": "TUNNEL_DO", "class_name": "Tunnel" }],
      },
    },
  },
}
