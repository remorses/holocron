{
  "name": "db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Drizzle schema and migrations for the Holocron D1 database",
  "exports": {
    ".": {
      "workerd": "./src/workerd.ts",
      "default": "./src/node.ts"
    },
    "./schema": "./src/schema.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc",
    "generate": "drizzle-kit generate && tsx scripts/flatten-migrations.ts ./drizzle",
    "flatten": "tsx scripts/flatten-migrations.ts ./drizzle"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "1.0.0-beta.21",
    "drizzle-orm": "1.0.0-beta.21",
    "typescript": "^6.0.2",
    "ulid": "^3.0.2"
  }
}
