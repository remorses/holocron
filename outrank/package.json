{
  "name": "@holocron.so/outrank",
  "version": "0.1.0",
  "description": "Outrank blog provider for Holocron documentation sites",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/holocron",
    "directory": "outrank"
  },
  "license": "MIT",
  "homepage": "https://holocron.so",
  "bugs": "https://github.com/remorses/holocron/issues",
  "keywords": [
    "holocron",
    "outrank",
    "blog",
    "seo",
    "content",
    "provider"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build"
  },
  "dependencies": {
    "@holocron.so/vite": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "rimraf": "^6.0.1"
  }
}
