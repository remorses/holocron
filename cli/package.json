{
  "name": "@holocron.so/cli",
  "version": "0.9.0",
  "description": "CLI for Holocron: manage API keys and authenticate with holocron.so",
  "keywords": [
    "cli",
    "holocron",
    "docs",
    "documentation",
    "api-keys"
  ],
  "homepage": "https://github.com/remorses/holocron",
  "bugs": "https://github.com/remorses/holocron/issues",
  "license": "MIT",
  "author": "remorses <beats.by.morse@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/holocron",
    "directory": "cli"
  },
  "bin": {
    "holocron": "dist/bin.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./src": {
      "types": "./src/cli.ts",
      "default": "./src/cli.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin.js && tsx scripts/copy-template.ts",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build",
    "cli": "tsx src/bin",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.2",
    "goke": "^6.10.0",
    "spiceflow": "1.25.0-rsc.0",
    "string-dedent": "^3.0.2",
    "yaml": "^2.8.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "website": "workspace:^"
  }
}
