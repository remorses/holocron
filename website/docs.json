{
    "$schema": "https://mintlify.com/docs.json",
    "name": "Holocron",
    "colors": {
        "primary": "#5b7cff"
    },
    "icons": { "library": "lucide" },
    "navbar": {
        "links": [
            {
                "type": "github",
                "href": "https://github.com/remorses/holocron"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Component Docs",
            "href": "/components"
        }
    },
    "navigation": {
        "tabs": [
            {
                "tab": "Documentation",
                "groups": [
                    {
                        "group": "Overview",
                        "icon": "sparkles",
                        "pages": ["index", "custom-entry"]
                    },
                    {
                        "group": "Components",
                        "icon": "blocks",
                        "pages": [
                            "components/index",
                            "components/accordions",
                            "components/badge",
                            "components/banner",
                            "components/callouts",
                            "components/cards",
                            "components/code-groups",
                            "components/color",
                            "components/columns",
                            "components/examples",
                            "components/expandables",
                            "components/fields",
                            "components/frames",
                            "components/icons",
                            "components/mermaid-diagrams",
                            "components/panel",
                            "components/prompt",
                            "components/responses",
                            "components/steps",
                            "components/tabs",
                            "components/tiles",
                            "components/tooltips",
                            "components/tree",
                            "components/update",
                            "components/view"
                        ]
                    }
                ]
            },
            {
                "tab": "API Reference",
                "openapi": "openapi.json"
            }
        ]
    }
}
