{
    "$schema": "https://mintlify.com/docs.json",
    "name": "Holocron",
    "description": "Mintlify-compatible docs site generator as a Vite plugin.",
    "colors": {
        "primary": "#5b7cff"
    },
    "icons": { "library": "lucide" },
    "navbar": {
        "links": [
            {
                "type": "github",
                "href": "https://github.com/remorses/holocron"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Components",
            "href": "/components"
        }
    },
    "navigation": {
        "tabs": [
            {
                "tab": "Documentation",
                "groups": [
                    {
                        "group": "Start",
                        "icon": "sparkles",
                        "pages": [
                            "index",
                            "what-is-holocron",
                            "quickstart",
                            "migration"
                        ]
                    },
                    {
                        "group": "Create",
                        "icon": "pencil",
                        "pages": [
                            "create/pages",
                            "create/mdx",
                            "create/code",
                            "create/images",
                            "create/local-imports",
                            "create/redirects"
                        ]
                    },
                    {
                        "group": "Organize",
                        "icon": "folder-tree",
                        "pages": [
                            "organize/docs-json",
                            "organize/navigation",
                            "organize/versions",
                            "organize/dropdowns",
                            "organize/hidden-pages",
                            "organize/pages-dir"
                        ]
                    },
                    {
                        "group": "Customize",
                        "icon": "palette",
                        "pages": [
                            "customize/theme",
                            "customize/fonts",
                            "customize/icons",
                            "customize/logo-and-favicon",
                            "customize/navbar-footer-banner",
                            "customize/custom-css",
                            "custom-entry"
                        ]
                    },
                    {
                        "group": "API Docs",
                        "icon": "braces",
                        "pages": [
                            "api-docs/openapi",
                            "api-docs/generated-pages",
                            "api-docs/request-response-examples",
                            "api-docs/troubleshooting"
                        ]
                    },
                    {
                        "group": "AI-Readable Docs",
                        "icon": "bot",
                        "pages": [
                            "ai/markdown-routes",
                            "ai/llms-txt",
                            "ai/docs-zip",
                            "ai/skill-discovery",
                            "ai/assistant"
                        ]
                    },
                    {
                        "group": "Deploy",
                        "icon": "cloud-upload",
                        "pages": [
                            "deploy/node",
                            "deploy/cloudflare",
                            "deploy/build-output",
                            "deploy/base-path"
                        ]
                    }
                ]
            },
            {
                "tab": "MDX Components",
                "icon": "blocks",
                "groups": [
                    {
                        "group": "Components",
                        "icon": "blocks",
                        "pages": [
                            "components/index",
                            "components/accordions",
                            "components/badge",
                            "components/banner",
                            "components/callouts",
                            "components/cards",
                            "components/code-groups",
                            "components/color",
                            "components/columns",
                            "components/examples",
                            "components/expandables",
                            "components/fields",
                            "components/frames",
                            "components/icons",
                            "components/mermaid-diagrams",
                            "components/panel",
                            "components/prompt",
                            "components/responses",
                            "components/steps",
                            "components/tabs",
                            "components/tiles",
                            "components/tooltips",
                            "components/tree",
                            "components/update",
                            "components/view",
                            "components/visibility"
                        ]
                    }
                ]
            },
            {
                "tab": "API Reference",
                "openapi": "openapi.json"
            }
        ]
    },
    // "decorativeLines": "none"
}
