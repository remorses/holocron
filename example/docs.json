{
  "$schema": "https://unpkg.com/@holocron.so/vite/src/schema.json",
  "name": "Playwriter",
  "logo": "/playwriter-logo.svg",
  "favicon": "/favicon-32.png",
  "colors": {
    "primary": "#3e9fff"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      { "type": "github", "href": "https://github.com/remorses/playwriter" },
      { "label": "Blog", "icon": "rss", "href": "https://example.com/blog" }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/introduction"
    }
  },
  "navigation": {
    "versions": [
      {
        "version": "v2",
        "default": true,
        "tag": "Latest",
        "groups": [
          {
            "group": "Overview",
            "icon": "compass",
            "pages": ["index"]
          },
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Guides",
            "icon": "map",
            "pages": ["navigation", "theming", "search"]
          },
          {
            "group": "Reference",
            "icon": "book",
            "pages": ["configuration", "frontmatter", "deployment", "custom-virtual-modules"]
          }
        ]
      },
      {
        "version": "v1",
        "tag": "Legacy",
        "groups": [
          {
            "group": "Overview",
            "pages": ["v1/overview"]
          },
          {
            "group": "Getting Started",
            "pages": ["v1/getting-started"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        { "anchor": "GitHub", "href": "https://github.com/remorses/playwriter", "icon": "github" },
        { "anchor": "Changelog", "href": "https://github.com/remorses/playwriter/releases", "icon": "newspaper" }
      ]
    }
  }
}
