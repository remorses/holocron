{
  "$schema": "https://holocron.so/docs.json?sdfsd",
  "name": "Playwriter",

  "logo": "/playwriter-logo.svg",
  "favicon": "/favicon-32.png",
  "colors": {
    "primary": "#3e9fff"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      { "type": "github", "href": "https://github.com/remorses/playwriter" },
      { "label": "Blog", "icon": "rss", "href": "https://example.com/blog" }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/introduction"
    }
  },
  "navigation": {
    "versions": [
      {
        "version": "v2",
        "default": true,
        "tag": "Latest",
        "tabs": [
          {
            "tab": "Documentation",
            "groups": [
              {
                "group": "Overview",
                "icon": "fontawesome:solid:compass",
                "pages": ["index"]
              },
              {
                "group": "Getting Started",
                "icon": "rocket",
                "pages": ["introduction", "quickstart"]
              },
              {
                "group": "Guides",
                "icon": "map",
                "pages": ["navigation", "theming", "search"]
              },
              {
                "group": "Reference",
                "icon": "book",
                "pages": ["configuration", "frontmatter", "deployment", "custom-virtual-modules"]
              }
            ]
          },
          {
            "tab": "API Reference",
            "icon": "code",
            "openapi": "api.yaml",
            "pages": ["api-authentication", "..."]
          }
        ]
      },
      {
        "version": "v1",
        "tag": "Legacy",
        "groups": [
          {
            "group": "Overview",
            "pages": ["v1/overview"]
          },
          {
            "group": "Getting Started",
            "pages": ["v1/getting-started"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        { "anchor": "GitHub", "href": "https://github.com/remorses/playwriter", "icon": "github", "placement": "sidebar" },
        { "anchor": "Discord", "href": "https://discord.gg/example", "icon": "message-circle", "placement": "sidebar" },
        { "anchor": "Changelog", "href": "https://github.com/remorses/playwriter/releases", "icon": "newspaper", "placement": "tabs" },
        { "anchor": "npm", "href": "https://www.npmjs.com/package/playwriter", "icon": "package", "placement": "tabs" }
      ]
    }
  }
}
