{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "holocron-og",
  "main": "src/index.tsx",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],

  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },

  "env": {
    "preview": {
      "name": "holocron-og-preview"
    }
  }
}
